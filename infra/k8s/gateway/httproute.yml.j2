apiVersion: gateway.networking.k8s.io/v1
kind: HTTPRoute
metadata:
  name: "{{ name }}"-route
  namespace: "{{ namespace }}"
spec:
  parentRefs:
    - name: apps-gateway
      namespace: default
  hostnames:
    - "{{ name }}.app.iti"
  rules:
    - matches:
        - path:
            type: PathPrefix
            value: /
      backendRefs:
        - name: "{{ service }}"
          port: "{{ port }}"
